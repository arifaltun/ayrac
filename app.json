{
  "expo": {
    "name": "ayrac",
    "slug": "ayrac",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ayrac",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Kitap barkodunu taramak ve kapak fotoğrafı çekmek için kamera kullanılıyor.",
        "NSPhotoLibraryUsageDescription": "Kitap kapağı seçmek ve paylaşım kartını galeriye kaydetmek için fotoğraf galerisine erişim gerekiyor.",
        "NSPhotoLibraryAddUsageDescription": "Paylaşım kartını fotoğraf galerisine kaydetmek için izin gerekiyor."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Kitap barkodunu taramak için kameraya erişim gerekiyor."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Paylaşım kartını galerine kaydetmek için izin gerekiyor."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Kitap kapağı seçmek için fotoğraf galerisine erişim gerekiyor.",
          "cameraPermission": "Kitap kapağı çekmek için kameraya erişim gerekiyor."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
